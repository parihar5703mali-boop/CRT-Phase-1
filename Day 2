// problem 4----ternary operator
// find the greater number among 2

#include<iostream>
using namespace std;

int main(){
    int a,b;
    int max_Number;
    
    cin >>a>>b;
    
    // ternary operator
    
    max_Number = a>b ? a:b;
    cout << max_Number;
    
    return 0;
}


// problem 5 ---continue statements
// print 1 to n and avoid those numbers which are divisible by 3 

#include<iostream>
 using namespace std;
 
 int main(){
     
     int n;
     cin >> n;
     for (int i = 1; i<=n; i++){
         if(i %3 == 0){
             continue;
             
         }
         cout << i << " ";
         
     }
        cout << "\n";
     return 0;
 }




// problem 6---break statements
// we have to add number until we get a negative number

#include<iostream>
using namespace std;

int main(){
    int n;
    int sum = 0;
    
    while(true){
        cin >> n;
        
        if(n<0){
            break;
            
        }
        sum = sum +n;
        
        
    }
    cout << sum;
     return 0;
}


