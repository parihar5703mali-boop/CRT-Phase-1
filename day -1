// swap values of 2 vARIABLES USING 3RD VARIABLES 


#include<iostream>
using namespace std;

int main(){
    int a;
    int b;
    
    cin>> a>> b;
    //swaping logical
    int temp = a;
    a =b;
    b = temp;
    
    cout<< a << "\n" << b << endl;
    return 0;
    
}



// Area of Shapes
// 1-- circle, 2--rectangle, 3-- triangle

#include<iostream>
using namespace std;

int main(){
    int choice;
    cin>> choice;
    
    if(choice == 1){
        double radius;
        cin >> radius;
        cout << 3.14 * radius * radius << endl;
    }else if(choice ==2){
        double lenght,width;
        cin >> lenght >> width;
        cout << lenght*width << endl;
    }else if (choice ==3){
        double base,height;
        cin>> base >> height;
        cout << 0.5 * base * height << endl;
    }else {
        cout << "invalid Choice" << endl;
    }
    
    return 0;
    
        
    
}
