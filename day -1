// temperature conversion
// take input in the form of celcius and converts it into fahrenheit..
#include<iostream>
using namespace std;

int main(){
    double celcius; 
    double fahrenheit;
    cin>> celcius;
    fahrenheit = (celcius*9.0/5.0) + 32.0;
    cout<< fahrenheit<< endl;
    
    return 0;
}

// Global vs Local variable

#include<iostream>
using namespace std;

//global variable
int globalVariable = 100;
int main(){
    // local variable
    int userInput;
    
    cin>> userInput;
    float result = (double)globalVariable / userInput;
    
    cout<< result << endl;
    return 0 ;
}
