//problem 7.3---
// Access specifier

#include <iostream>
using namespace std;

class Parent {
    protected :
    
    
    int secretCode = 1234;
    
};

class child : public Parent{
    public:
    void accessOfSecretCode(){
        cout<< "secretCodeof the locker" << secretCode;
    }
    
};

int main(){
    child obj1;
    obj1.accessOfSecretCode();
}


