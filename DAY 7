//Problem 3 -- Access Specifier
//Use all the access specifiers in one program

#include <iostream>
using namespace std;

class Bank{
    public:
    string name = "LAXMI CHIT FUND \n"; 
    void showBalance(){
        cout << "Your balance is: " << balance;
    }
    
    private: 
    int balance = 22;
    
    protected:
    int pin = 2048;
};

class Child : public Bank{
    public:
    void accessOfPin(){
        cout << "\nYour Account Pin is: " << pin;
    }
};



int main()
{
    Bank b;
    cout << b.name;
    b.showBalance();
    Child c;
    c.accessOfPin();
    
    
}

