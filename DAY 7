// 2.2--parameterized constructor---

#include<iostream>
using namespace std;

class Student {
    public :
    
    string name ;
    int Id;
    
    Student(string studentsName , int studentId){
        name = studentsName;
        Id =studentId;
    }
    void displayDetails(){
        cout << name << Id;
        
    }
};

int main(){
    Student std1("Ravi ", 2193);
    std1.displayDetails();
}

