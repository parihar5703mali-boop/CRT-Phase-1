// problems 5---
//smart ac remote// function overloading // defulat arguments...

#include<iostream>
using namespace std;

void setTemperature(int temp = 22){
    cout <<"Temperature set to "<< temp << "°C" << "\n";
}

void setTemperature(double temp){
    cout << "Temperature set to "<< temp << "°C" << "\n";
}

void setTemperature(string mode){
    if(mode == "ECO"){
        cout << "Temperature set to 24°C " << "\n";
        
    }
    else if(mode == "TURBO"){
        cout << "Temperature set to 18°C " << "\n";
    }
    
}

int main(){
    setTemperature();  // defulatvalue --22 
    setTemperature(20.5); // manually setting the Temperature
    setTemperature("ECO"); // SET TemperatureTO 24
    setTemperature("TURBO"); // set Temperature TO 18
    
    
}


