//problem 3----
//Calll by value // Call by reference
// Call by value ---Photocopy
// Call by value --original copy(address)

#include<iostream>
using namespace std;

void updatebyValue(int a){
    a =500;
}
void updatebyReference(int &a){
    a =500;
}

int main(){
    
    int original = 100;
    cout << original << "\n";
    
    
    updatebyValue(original);
    cout << original << "\n";
    
    updatebyReference(original);
    cout << original;
    
}

