// Problem 1--
// Inheritence...
// types of Inheritence...1.3 Heirarchal Inheritence.

#include <iostream>
using namespace std;

class Vehicle {
    public :
    
    void start(){
        cout << "Vehicle Starts" << "\n";
    }
};

class Car :  public Vehicle {
    public :
    
    void drive(){
        cout << "Car is running" << "\n";
    }
};

class bike : public Vehicle {
    public :
    void drive(){
        cout << "bike is running at 1000km/h" <<"\n";
    }
};

int main(){
    Car obj1;
    obj1.drive();
    obj1.start();
    bike obj2;
    obj2.drive();
    obj2.start();
    

    return 0;
}



